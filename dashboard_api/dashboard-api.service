[Unit]
Description=Wealth Dashboard API and Frontend
After=network.target

[Service]
Type=simple
User=cheesus
WorkingDirectory=/home/cheesus/proyectos/finances_dbt_bq
ExecStart=/home/cheesus/proyectos/finances_dbt_bq/venv/bin/uvicorn dashboard_api.app:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
